#jinja2: lstrip_blocks:True
#jinja2: trim_blocks:True
global
    log /dev/log    local0
    log /dev/log    local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 expose-fd listeners level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    hard-stop-after 10m

    # modern configuration from
    #  https://mozilla.github.io/server-side-tls/ssl-config-generator/?server=haproxy

    # NOTE: Not using the modern setting as the jitsi mobile app won't support it

    # intermediate configuration
    ssl-default-bind-curves X25519MLKEM768:X25519:prime256v1:secp384r1
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options prefer-client-ciphers ssl-min-ver TLSv1.2 no-tls-tickets

    ssl-default-server-curves X25519MLKEM768:X25519:prime256v1:secp384r1
    ssl-default-server-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305
    ssl-default-server-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-server-options ssl-min-ver TLSv1.2 no-tls-tickets

    tune.ssl.default-dh-param 2048

    {% if haproxy_lb_quic_enabled | default(false) %}
    # Preserve cap_net_bind_service across uid switch so the haproxy worker
    # can bind QUIC UDP sockets on privileged ports (443) after dropping
    # privileges to the haproxy user.
    setcap cap_net_bind_service
    # QUIC DDoS protection: force Retry token exchange above threshold
    tune.quic.retry-threshold 100
    {% endif %}

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  dontlog-normal

    timeout connect 5000
    timeout client  300000
    timeout server  300000

    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

# Authentication
{% for group in haproxy_lb_auth %}
userlist {{ group.group }}
    {% for user in group.users %}
    user {{ user.name }} password {{ user.password | password_hash(hashtype='sha256', rounds=1000) }}
    {% endfor %}
{% endfor %}

{% if haproxy_lb_cache_enabled | default(false) %}
cache global_cache
  total-max-size 512 # 512 MB
  max-object-size 102400 # 100 KB
  max-age 600 # Stay in cache for 10 minutes
  process-vary on
  max-secondary-entries 12
{% endif %}

listen stats
    bind 127.0.0.1:32700
    stats enable
    stats uri /
    stats hide-version
    stats auth {{ haproxy_lb_stats_user }}:{{ haproxy_lb_stats_password }}

frontend prometheus
    bind 127.0.0.1:9142
    mode http
    no log
    http-request use-service prometheus-exporter if { path /metrics }

{# Build the domain-group map once at the top so both frontends and the
   backend section below see the same populated dict. #}
{% set domain_groups = {} %}
{% if haproxy_lb_sites and haproxy_lb_sites|length > 0 %}
{% for host, hostvars in lb_hostvars.items() %}
{% for svc in hostvars.services if svc.custom_fields.expose_mode is defined and svc.custom_fields.expose_mode == "l7" %}
{% for domain in svc.custom_fields.expose_domain.split(',') | map('trim') | list %}
{% if domain not in domain_groups %}
{% set _ = domain_groups.update({domain: []}) %}
{% endif %}
{% set _ = domain_groups[domain].append({'host': host, 'svc': svc, 'hostvars': hostvars}) %}
{% endfor %}
{% endfor %}
{% endfor %}
{% endif %}

{% if haproxy_lb_sites and haproxy_lb_sites|length > 0 %}
frontend http
    bind *:80
    bind [::]:80 v6only
    mode http

    {% if haproxy_lb_log_http_requests | default(true) %}
    # Discovery logging: log every request hitting :80 so we can see which
    # clients still use HTTP before enabling haproxy_lb_force_https.
    no option dontlog-normal
    {% endif %}

    # Capture request URI for redirect preservation
    http-request capture path len 512

    {% if (haproxy_lb_force_https | default(false)) and (not haproxy_lb_sites_insecure) %}
    {# Route only services that opt in to plain HTTP; everything else falls
       through to the default scheme redirect below. The include populates
       `is_allow_http` with each opt-in service's host patterns; the baseline
       below keeps the ACL defined even when no services opt in. #}
    acl is_allow_http always_false
    {% set routing_filter_allow_http = true %}
    {% include '_http_routing.j2' %}

    http-request redirect scheme https code 301 unless is_allow_http
    {% else %}
    {# Pre-flip mode: route HTTP the same as HTTPS so existing clients keep
       working while we observe logs. #}
    {% set routing_filter_allow_http = false %}
    {% include '_http_routing.j2' %}
    {% endif %}

    default_backend default

{% if not haproxy_lb_sites_insecure %}
frontend https
    bind *:443 ssl crt /etc/certificates/ alpn h2,http/1.1
    bind [::]:443 v6only ssl crt /etc/certificates/ alpn h2,http/1.1
    {% if haproxy_lb_quic_enabled | default(false) %}
    bind quic4@:443 ssl crt /etc/certificates/ alpn h3
    bind quic6@:443 v6only ssl crt /etc/certificates/ alpn h3
    {% endif %}
    mode http

    # HSTS (63072000 seconds)
    http-response set-header Strict-Transport-Security max-age=63072000

    {% if haproxy_lb_quic_enabled | default(false) %}
    # Advertise HTTP/3 availability to browsers
    http-response set-header Alt-Svc "h3=\":443\"; ma=86400"
    {% endif %}

    # Capture request URI for redirect preservation
    http-request capture path len 512

    {% set routing_filter_allow_http = false %}
    {% include '_http_routing.j2' %}

    default_backend default
{% endif %}
{% endif %}

### TCP Frontends

{# Group TCP-exposed k8s services by ethquokkaops.io/balance-group. Services without a
   balance-group are emitted one-per-service as before (legacy path, byte-identical
   output). Services sharing a balance-group are collapsed into a single frontend +
   backend pair so HAProxy sees N pod-pinned LoadBalancer IPs as one backend, enabling
   `balance source` (or other algorithms) to hash agent IPs deterministically to a
   specific pod. #}
{% set tcp_groups = namespace(map={}, ungrouped=[]) %}
{% for cluster in haproxy_lb_k8s_services %}
{% for svc in cluster.resources if svc.metadata.annotations["ethquokkaops.io/expose-tcp"] is defined %}
{% set group = svc.metadata.annotations.get("ethquokkaops.io/balance-group") %}
{% if group %}
{% set key = cluster.item ~ "__" ~ group %}
{% if key not in tcp_groups.map %}
{% set _ = tcp_groups.map.update({key: {
  "cluster": cluster.item,
  "group": group,
  "port": svc.metadata.annotations["ethquokkaops.io/expose-on-port"],
  "balance": svc.metadata.annotations.get("ethquokkaops.io/balance", "roundrobin"),
  "max_conn": svc.metadata.annotations.get("ethquokkaops.io/max-conn", "30"),
  "timeout": svc.metadata.annotations.get("ethquokkaops.io/timeout"),
  "services": []
}}) %}
{% endif %}
{% set _ = tcp_groups.map[key].services.append(svc) %}
{% else %}
{% set _ = tcp_groups.ungrouped.append({"cluster": cluster.item, "svc": svc}) %}
{% endif %}
{% endfor %}
{% endfor %}

{% for tun in haproxy_lb_tunnels %}
frontend fe_{{ tun }}
    bind *:{{ haproxy_lb_tunnels[tun].port }}
    bind [::]:{{ haproxy_lb_tunnels[tun].port }} v6only
    mode tcp
    option tcplog
    default_backend tcp_{{ tun }}
{% endfor %}

{% for item in tcp_groups.ungrouped %}
{% set svc = item.svc %}

frontend fe_{{ item.cluster }}_{{ svc.metadata.namespace }}_{{ svc.metadata.name }}
    bind *:{{ svc.metadata.annotations["ethquokkaops.io/expose-on-port"] }}
    bind [::]:{{ svc.metadata.annotations["ethquokkaops.io/expose-on-port"] }} v6only
    mode tcp
    option tcplog
    default_backend tcp_{{ item.cluster }}_{{ svc.metadata.namespace }}_{{ svc.metadata.name }}

{% endfor %}

{% for key, g in tcp_groups.map | dictsort %}

frontend fe_{{ g.cluster }}_{{ g.group }}
    bind *:{{ g.port }}
    bind [::]:{{ g.port }} v6only
    mode tcp
    option tcplog
    default_backend tcp_{{ g.cluster }}_{{ g.group }}

{% endfor %}


############
# BACKENDS #
############

backend Abuse
    stick-table type ip size 100K expire 30m store gpc0,http_req_rate(60s)

backend default
    balance roundrobin
    option forwardfor

    # Redirects

    {% if haproxy_lb_redirects is defined %}
    {% for redirect in haproxy_lb_redirects %}

    {% if redirect.match is defined %}
    acl redir_match_{{ loop.index }} path_reg {{ redirect.match }}
    http-request redirect code 301 location {{ redirect.dest }} if redir_match_{{ loop.index }}
    {% endif %}

    {% if redirect.domain is defined %}
    acl redir_host_{{ loop.index }} hdr(host) -i {{ redirect.domain }}
    acl redir_host_{{ loop.index }} hdr(host) -i {{ redirect.domain }}:80
    acl redir_host_{{ loop.index }} hdr(host) -i {{ redirect.domain }}:443
    http-request redirect code 301 location {{ redirect.dest }} if redir_host_{{ loop.index }}
    {% endif %}

    {% endfor %}
    {% endif %}

    errorfile 503 /etc/haproxy/errors/default.http


{% for site in haproxy_lb_sites %}
backend {{ site }}
    option forwardfor
    option forwarded

    # keep websockets around for 2h
    timeout tunnel 2h

    # only keep clients in the connection queue for 1 minute
    timeout queue 60s

    http-request set-header X-Forwarded-Port %[dst_port]
    http-request add-header X-Forwarded-Proto https if { ssl_fc }

    {% if haproxy_lb_sites[site].backend_mode | default("http") != "grpc" %}
    # Enable compression towards the client
    filter compression
    compression algo gzip
    compression type text/css text/html text/javascript application/javascript text/plain text/xml application/json
    compression offload
    {% endif %}

    {% if haproxy_lb_sites[site]["auth"] is defined %}
    acl basic-auth http_auth({{ haproxy_lb_sites[site]["auth"] }})
    http-request auth realm {{ site }} unless basic-auth
    http-request del-header Authorization
    {% endif %}

    {% if haproxy_lb_sites[site]["set_path"] is defined %}
    http-request set-path {{ haproxy_lb_sites[site]["set_path"] }}
    {% endif %}

    {% if haproxy_lb_sites[site]["use_sticky"] is defined %}
    cookie SERVER_USED insert indirect nocache
    {% endif %}

    default-server check maxconn {{ haproxy_lb_sites[site].max_conn | default('500') }} fall 3 rise 2 {{ 'ssl verify none' if haproxy_lb_sites[site].sslbackend is defined else '' }} {{ 'alpn h2,http/1.1' if haproxy_lb_sites[site].http2 is defined else '' }} {{ 'cookie s' if haproxy_lb_sites[site]["use_sticky"] is defined }}{{ loop.index if haproxy_lb_sites[site]["use_sticky"] is defined }} {{ 'proto h2' if haproxy_lb_sites[site].backend_mode | default("http") == "grpc" else '' }}

    {% if haproxy_lb_sites[site].balance_mode is defined and haproxy_lb_sites[site].balance_mode == "backup" %}
    balance first

    {% if haproxy_lb_clusters[haproxy_lb_sites[site].cluster]["nodes"] is defined %}
    {% for server in haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodes %}
    {% if loop.first %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }}
    {% else %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }} backup
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if haproxy_lb_clusters[haproxy_lb_sites[site].cluster]["nodeGroup"] is defined %}
    {% for server in groups[haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodeGroup] %}
    {% if loop.first %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }}
    {% else %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }} backup
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if haproxy_lb_clusters[haproxy_lb_sites[site].cluster]["nodeGroups"] is defined %}
        # Using nodegroups
        {% set first_group = haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodeGroups[0] %}
        {% set target_servers = groups[first_group] | intersect(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodeGroups[1:] | map('extract', groups) | list) %}
        {% for server in target_servers %}
        {% if loop.first %}
        server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }}
        {% else %}
        server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }} backup
        {% endif %}
        {% endfor %}
    {% endif %}

    {% else %}
    balance roundrobin

    {% if haproxy_lb_clusters[haproxy_lb_sites[site].cluster]["nodes"] is defined %}
    {% for server in haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodes %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }}
    {% endfor %}
    {% endif %}

    {% if haproxy_lb_clusters[haproxy_lb_sites[site].cluster]["nodeGroup"] is defined %}
    {% for server in groups[haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodeGroup] %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }}
    {% endfor %}
    {% endif %}

    {% if haproxy_lb_clusters[haproxy_lb_sites[site].cluster]["nodeGroups"] is defined %}
        # Using nodegroups
        {% set first_group = haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodeGroups[0] %}
        {% set target_servers = groups[first_group] | intersect(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].nodeGroups[1:] | map('extract', groups) | list) %}
        {% for server in target_servers %}
        server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_sites[site].port | default(haproxy_lb_clusters[haproxy_lb_sites[site].cluster].defaultPort | default('80')) }}
        {% endfor %}
    {% endif %}

    {% endif %}
    {% if haproxy_lb_backend_extra_config is defined and site in haproxy_lb_backend_extra_config %}
    # Custom backend configuration
{{ haproxy_lb_backend_extra_config[site] | indent(4, first=True) }}
    {% endif %}
{% endfor %}

{% for cluster in haproxy_lb_k8s_services %}
{% for svc in cluster.resources if svc.metadata.annotations["ethquokkaops.io/expose-public"] is defined and (svc.metadata.annotations["ethquokkaops.io/domain"] is defined or svc.metadata.annotations["ethquokkaops.io/domain-port-map"] is defined) %}
{% if svc.metadata.annotations["ethquokkaops.io/domain-port-map"] is defined %}
{# Multi-port mapping: create a backend for each unique port #}
{% set port_mappings = svc.metadata.annotations["ethquokkaops.io/domain-port-map"].split(',') | map('trim') | list %}
{% set ns = namespace(processed_ports=[]) %}
{% for mapping in port_mappings %}
{% set portname = mapping.split(':')[0] | trim %}
{% if portname not in ns.processed_ports %}
{% set _ = ns.processed_ports.append(portname) %}
{# Find the port number for this port name #}
{% set port_ns = namespace(port_number=None) %}
{% for port in svc.spec.ports %}
{% if port.name == portname %}
{% set port_ns.port_number = port.port %}
{% endif %}
{% endfor %}

{# Determine backend mode for this port: backend-mode-map (per-port) > backend-mode (all ports) > "http" #}
{% set ns_bm = namespace(mode="http") %}
{% if svc.metadata.annotations["ethquokkaops.io/backend-mode-map"] is defined %}
{% for bm_entry in svc.metadata.annotations["ethquokkaops.io/backend-mode-map"].split(',') | map('trim') | list %}
{% if bm_entry.split(':')[0] | trim == portname %}
{% set ns_bm.mode = bm_entry.split(':')[1] | trim %}
{% endif %}
{% endfor %}
{% elif svc.metadata.annotations["ethquokkaops.io/backend-mode"] is defined %}
{% set ns_bm.mode = svc.metadata.annotations["ethquokkaops.io/backend-mode"] %}
{% endif %}

backend {{ cluster.item }}_{{ svc.metadata.namespace }}_{{ svc.metadata.name }}_{{ portname }}
    balance roundrobin
    option forwardfor
    option forwarded

    # keep websockets around for 2h
    timeout tunnel 2h

    # only keep clients in the connection queue for 1 minute
    timeout queue 60s

    {% if svc.metadata.annotations["ethquokkaops.io/timeout"] is defined %}
    timeout client {{ svc.metadata.annotations["ethquokkaops.io/timeout"] }}
    timeout server {{ svc.metadata.annotations["ethquokkaops.io/timeout"] }}
    {% endif %}

    http-request set-header X-Forwarded-Port %[dst_port]
    http-request add-header X-Forwarded-Proto https if { ssl_fc }

    {% if svc.metadata.annotations["ethquokkaops.io/path"] is defined %}
    {% for path in svc.metadata.annotations["ethquokkaops.io/path"].split(',') | map('trim') | list %}
    {% if ':' in path %}
    {% set public_path = path.split(':')[0] | trim %}
    {% set backend_path = path.split(':')[1] | trim %}
    http-request replace-path ^{{ public_path }}(.*) {{ backend_path }}\1
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if ns_bm.mode != "grpc" %}
    # Enable compression towards the client
    filter compression
    compression algo gzip
    compression type text/css text/html text/javascript application/javascript text/plain text/xml application/json
    compression offload
    {% endif %}

    {% if svc.metadata.annotations["ethquokkaops.io/sticky"] is defined and svc.metadata.annotations["ethquokkaops.io/sticky"] == 'true' %}
    cookie SERVER_USED insert indirect nocache
    {% endif %}

    default-server check maxconn {{ svc.metadata.annotations["ethquokkaops.io/max-conn"] | default('500') }} fall 3 rise 2 {{ 'ssl verify none' if svc.metadata.annotations["ethquokkaops.io/ssl-backend"] is defined else '' }} {{ 'alpn h2,http/1.1' if svc.metadata.annotations["ethquokkaops.io/http2-backend"] is defined else '' }} {{ 'cookie s' if svc.metadata.annotations["ethquokkaops.io/sticky"] is defined }} {{ 'proto h2' if ns_bm.mode == "grpc" else '' }}

    server lb_{{ svc.metadata.name }}_{{ portname }} {{ svc.status.loadBalancer.ingress[0].ip }}:{{ port_ns.port_number }}
    {% set k8s_backend_name = cluster.item ~ '_' ~ svc.metadata.namespace ~ '_' ~ svc.metadata.name ~ '_' ~ portname %}
    {% if haproxy_lb_backend_extra_config is defined and k8s_backend_name in haproxy_lb_backend_extra_config %}
    # Custom backend configuration
{{ haproxy_lb_backend_extra_config[k8s_backend_name] | indent(4, first=True) }}
    {% endif %}

{% endif %}
{% endfor %}
{% else %}
{# Standard single-backend routing #}
backend {{ cluster.item }}_{{ svc.metadata.namespace }}_{{ svc.metadata.name }}
    balance roundrobin
    option forwardfor
    option forwarded

    # keep websockets around for 2h
    timeout tunnel 2h

    # only keep clients in the connection queue for 1 minute
    timeout queue 60s

    {% if svc.metadata.annotations["ethquokkaops.io/timeout"] is defined %}
    timeout client {{ svc.metadata.annotations["ethquokkaops.io/timeout"] }}
    timeout server {{ svc.metadata.annotations["ethquokkaops.io/timeout"] }}
    {% endif %}

    http-request set-header X-Forwarded-Port %[dst_port]
    http-request add-header X-Forwarded-Proto https if { ssl_fc }

    {% if svc.metadata.annotations["ethquokkaops.io/path"] is defined %}
    {% for path in svc.metadata.annotations["ethquokkaops.io/path"].split(',') | map('trim') | list %}
    {% if ':' in path %}
    {% set public_path = path.split(':')[0] | trim %}
    {% set backend_path = path.split(':')[1] | trim %}
    http-request replace-path ^{{ public_path }}(.*) {{ backend_path }}\1
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if svc.metadata.annotations["ethquokkaops.io/backend-mode"] | default("http") != "grpc" %}
    # Enable compression towards the client
    filter compression
    compression algo gzip
    compression type text/css text/html text/javascript application/javascript text/plain text/xml application/json
    compression offload
    {% endif %}


    {% if svc.metadata.annotations["ethquokkaops.io/sticky"] is defined and svc.metadata.annotations["ethquokkaops.io/sticky"] == 'true' %}
    cookie SERVER_USED insert indirect nocache
    {% endif %}

    default-server check maxconn {{ svc.metadata.annotations["ethquokkaops.io/max-conn"] | default('500') }} fall 3 rise 2 {{ 'ssl verify none' if svc.metadata.annotations["ethquokkaops.io/ssl-backend"] is defined else '' }} {{ 'alpn h2,http/1.1' if svc.metadata.annotations["ethquokkaops.io/http2-backend"] is defined else '' }} {{ 'cookie s' if svc.metadata.annotations["ethquokkaops.io/sticky"] is defined }}{{ loop.index if svc.metadata.annotations["ethquokkaops.io/sticky"] is defined }} {{ 'proto h2' if svc.metadata.annotations["ethquokkaops.io/backend-mode"] | default("http") == "grpc" else '' }}

    server lb_{{ svc.metadata.name }} {{ svc.status.loadBalancer.ingress[0].ip }}:{{ svc.spec.ports[0].port }}
    {% set k8s_backend_name = cluster.item ~ '_' ~ svc.metadata.namespace ~ '_' ~ svc.metadata.name %}
    {% if haproxy_lb_backend_extra_config is defined and k8s_backend_name in haproxy_lb_backend_extra_config %}
    # Custom backend configuration
{{ haproxy_lb_backend_extra_config[k8s_backend_name] | indent(4, first=True) }}
    {% endif %}

{% endif %}
{% endfor %}

{% endfor %}{# legacy outer cluster loop close, retained for backward compatibility of any nested logic above #}

{# Ungrouped TCP backends (legacy path, byte-identical to pre-balance-group behavior). #}
{% for item in tcp_groups.ungrouped %}
{% set svc = item.svc %}
backend tcp_{{ item.cluster }}_{{ svc.metadata.namespace }}_{{ svc.metadata.name }}
    mode tcp
    balance roundrobin

    {% if svc.metadata.annotations["ethquokkaops.io/timeout"] is defined %}
    timeout client {{ svc.metadata.annotations["ethquokkaops.io/timeout"] }}
    timeout server {{ svc.metadata.annotations["ethquokkaops.io/timeout"] }}
    {% endif %}
    default-server check maxconn {{ svc.metadata.annotations["ethquokkaops.io/max-conn"] | default('30') }} fall 3 rise 2
    server lb_{{ svc.metadata.name }} {{ svc.status.loadBalancer.ingress[0].ip }}:{{ svc.metadata.annotations["ethquokkaops.io/service-port"] | default(svc.spec.ports[0].port) }}
    {% set k8s_tcp_backend_name = 'tcp_' ~ item.cluster ~ '_' ~ svc.metadata.namespace ~ '_' ~ svc.metadata.name %}
    {% if haproxy_lb_backend_extra_config is defined and k8s_tcp_backend_name in haproxy_lb_backend_extra_config %}
    # Custom backend configuration
{{ haproxy_lb_backend_extra_config[k8s_tcp_backend_name] | indent(4, first=True) }}
    {% endif %}
{% endfor %}

{# Grouped TCP backends: one backend per (cluster, balance-group) with N server lines,
   one per member service. Balance algorithm comes from ethquokkaops.io/balance. #}
{% for key, g in tcp_groups.map | dictsort %}
backend tcp_{{ g.cluster }}_{{ g.group }}
    mode tcp
    balance {{ g.balance }}

    {% if g.timeout %}
    timeout client {{ g.timeout }}
    timeout server {{ g.timeout }}
    {% endif %}
    default-server check maxconn {{ g.max_conn }} fall 3 rise 2
    {% for svc in g.services %}
    server lb_{{ svc.metadata.name }} {{ svc.status.loadBalancer.ingress[0].ip }}:{{ svc.metadata.annotations["ethquokkaops.io/service-port"] | default(svc.spec.ports[0].port) }}
    {% endfor %}
    {% set k8s_tcp_backend_name = 'tcp_' ~ g.cluster ~ '_' ~ g.group %}
    {% if haproxy_lb_backend_extra_config is defined and k8s_tcp_backend_name in haproxy_lb_backend_extra_config %}
    # Custom backend configuration
{{ haproxy_lb_backend_extra_config[k8s_tcp_backend_name] | indent(4, first=True) }}
    {% endif %}
{% endfor %}

{% if haproxy_lb_tunnels is defined %}
{% for tun in haproxy_lb_tunnels %}
backend tcp_{{ tun }}
    mode tcp
    balance roundrobin

    default-server check maxconn {{ haproxy_lb_tunnels[tun].maxconn | default('500') }} fall 3 rise 2

    {% if haproxy_lb_clusters[haproxy_lb_tunnels[tun].cluster]["nodes"] is defined %}
    {% for server in haproxy_lb_clusters[haproxy_lb_tunnels[tun].cluster].nodes %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_tunnels[tun].cluster_port }}
    {% endfor %}
    {% endif %}

    {% if haproxy_lb_clusters[haproxy_lb_tunnels[tun].cluster]["nodeGroup"] is defined %}
    {% for server in groups[haproxy_lb_clusters[haproxy_lb_tunnels[tun].cluster].nodeGroup] %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_tunnels[tun].cluster_port }}
    {% endfor %}
    {% endif %}

    {% if haproxy_lb_clusters[haproxy_lb_tunnels[tun].cluster]["nodeGroups"] is defined %}
    # using nodegroups

    {% set node_groups = haproxy_lb_clusters[haproxy_lb_tunnels[tun].cluster].nodeGroups %}
    {% if node_groups | length > 0 %}
      {% set outer_target_servers = groups[node_groups[0]] %}

      {% set ns = namespace(servers=outer_target_servers) %}
      # start group {{ node_groups[0] }}
      {% for group_name in node_groups[1:] %}
      # intersecting {{ group_name }}
          {% set ns.servers = ns.servers | intersect(groups[group_name]) %}
      {% endfor %}
      {% set target_servers = ns.servers %}
    {% else %}
      {% set target_servers = [] %}
    {% endif %}
    # FINAL: {{ target_servers | join(', ')}}
    {% for server in target_servers %}
    server {{ server }} {{ lb_hostvars[server]["primary_ip4"] }}:{{ haproxy_lb_tunnels[tun].cluster_port }}
    {% endfor %}
    {% endif %}

{% endfor %}
{% endif %}

{# Create shared backends for load balancing services with same domain #}
{% for domain, services in domain_groups.items() %}
{% set backend_name = 'lb_' + (domain | replace('.', '_') | replace('-', '_') | replace('*','_')) %}
backend {{ backend_name }}
    option forwardfor
    option forwarded

    # keep websockets around for 2h
    timeout tunnel 2h

    # only keep clients in the connection queue for 1 minute
    timeout queue 60s

    http-request set-header X-Forwarded-Port %[dst_port]
    http-request add-header X-Forwarded-Proto https if { ssl_fc }

    {% if services[0].svc.custom_fields.backend_mode | default("http") != "grpc" %}
    # Enable compression towards the client
    filter compression
    compression algo gzip
    compression type text/css text/html text/javascript application/javascript text/plain text/xml application/json
    compression offload
    {% endif %}

    default-server check fall 3 rise 2 {{ 'proto h2' if services[0].svc.custom_fields.backend_mode | default("http") == "grpc" else '' }}
    {% if haproxy_lb_backend_extra_config is defined and domain in haproxy_lb_backend_extra_config %}
    # Custom backend configuration
{{ haproxy_lb_backend_extra_config[domain] | indent(4, first=True) }}
    {% endif %}

    {% if services[0].svc.custom_fields.balance_mode is defined and services[0].svc.custom_fields.balance_mode == "backup" %}
    balance first

    # Load balanced servers for domain: {{ domain }}
    {% for service_info in services %}
    {% if loop.first %}
    server {{ service_info.host }}_{{ service_info.svc.name }} {{ service_info.hostvars.primary_ip4 }}:{{ service_info.svc.ports[0] }}
    {% else %}
    server {{ service_info.host }}_{{ service_info.svc.name }} {{ service_info.hostvars.primary_ip4 }}:{{ service_info.svc.ports[0] }} backup
    {% endif %}
    {% endfor %}

    {% else %}
    balance roundrobin

    # Load balanced servers for domain: {{ domain }}
    {% for service_info in services %}
    server {{ service_info.host }}_{{ service_info.svc.name }} {{ service_info.hostvars.primary_ip4 }}:{{ service_info.svc.ports[0] }}
    {% endfor %}
    {% endif %}

{% endfor %}
